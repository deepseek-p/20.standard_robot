# ============================================================
# STM32 + Keil MDK (uVision5) 项目 .gitignore
# 适用目录结构：MDK-ARM / application / Core / Drivers
# ============================================================

# ------------------------------------------------------------
# 1) 编译/链接生成文件（通用）
# ------------------------------------------------------------
*.o
*.obj
*.d
*.dep
*.crf
*.axf
*.elf
*.hex
*.bin
*.map
*.lst
*.lnp
*.iex
*.sbr

# 注意：工程内存在需要入库的预编译算法库，不做全局 *.lib 忽略
MDK-ARM/**/*.lib
!components/algorithm/*.lib

# ------------------------------------------------------------
# 2) Keil MDK 输出目录
# 说明：这些目录通常仅包含中间产物与列表文件
# ------------------------------------------------------------
MDK-ARM/Objects/
MDK-ARM/Listings/
MDK-ARM/**/Objects/
MDK-ARM/**/Listings/

# 部分版本会在 MDK-ARM 目录下生成报告文件
MDK-ARM/*.htm
MDK-ARM/*.html
MDK-ARM/**/*.htm
MDK-ARM/**/*.html

# ------------------------------------------------------------
# 3) Keil 用户本地配置（与个人环境相关，不应入库）
# ------------------------------------------------------------
*.uvoptx
*.uvguix.*
*.uvgui.*
*.uvmpw

# 调试器本地配置
MDK-ARM/DebugConfig/

# ------------------------------------------------------------
# 4) 临时文件与日志
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
*~
Thumbs.db
Desktop.ini
.DS_Store

# ------------------------------------------------------------
# 5) 明确保留：源码/启动文件/链接脚本/工程文件
# 说明：避免后续新增通配规则时误伤
# ------------------------------------------------------------
!*.c
!*.h
!*.s
!*.S
!*.sct
!*.ld
!*.uvprojx

# ------------------------------------------------------------
# 6) Claude Code 本地配置
# ------------------------------------------------------------
.claude/
.mcp.json

# ------------------------------------------------------------
# 7) 第三方资料目录（不入库）
# ------------------------------------------------------------
YD-ESP32-S3资料/

# local reference repos (do not track)
HUST_Infantry_2023/
WH_Infantry_2025/

